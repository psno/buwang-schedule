	<string>不忘课表需要访问您的日历，以便将课程同步到系统日历中，方便您查看课程安排</string>

	<!-- 日历访问权限（iOS 16 及以下） -->
	<key>NSCalendarsUsageDescription</key>
	<string>不忘课表需要访问您的日历，以便将课程同步到系统日历中</string>

	<!-- 本地网络权限（部分插件需要） -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>不忘课表需要本地网络权限以支持部分功能</string>

</dict>
</plist>
